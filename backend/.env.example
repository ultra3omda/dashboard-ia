# ═══════════════════════════════════════════════════════════════════
# CashFlow Pilot Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── MongoDB ────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
DB_NAME=cashflow_pilot

# ─── Auth ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7
COOKIE_SECURE=false          # Set true in production (HTTPS only)
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=               # Leave empty in dev, set to your domain in prod

# ─── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI Suggestions (Claude API) ────────────────────────────────────
# Optional. If absent, the backend falls back to scripted suggestions.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
AI_SUGGESTIONS_CACHE_TTL_SECONDS=3600

# ─── Email (Resend) ─────────────────────────────────────────────────
# Optional. If absent, emails are logged instead of sent (dev mode).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=CashFlow Pilot
